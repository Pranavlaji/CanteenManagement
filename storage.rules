rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Unified role detection: prioritize custom claims, fall back to email pattern.
    // Matches the same logic used in firestore.rules and auth-provider.tsx.
    function role() {
      return request.auth == null ? "student" :
        (request.auth.token.role is string
          ? request.auth.token.role
          : (request.auth.token.email.matches(".*@canteen\\.internal")
              ? (request.auth.token.email.matches("^admin.*") ? "admin" : "staff")
              : "student"
            )
        );
    }

    function admin() {
      return role() == "admin";
    }

    match /menu/{allPaths=**} {
      allow read: if true;
      allow write: if admin()
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType in ["image/jpeg", "image/png"];
    }
  }
}
