NEXT_PUBLIC_ENABLE_FIREBASE_AUTH=true
REVALIDATE_SECRET=

# Server-only Firebase Admin credentials for production API routes.
# Use either FIREBASE_SERVICE_ACCOUNT_KEY as the full service-account JSON,
# or the split FIREBASE_PROJECT_ID / FIREBASE_CLIENT_EMAIL / FIREBASE_PRIVATE_KEY values.
FIREBASE_SERVICE_ACCOUNT_KEY=
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
