rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function role() {
      return !signedIn() ? "student" :
        request.auth.token.get("role", 
          request.auth.token.get("email", "").matches(".*@canteen\\.internal") ? 
            (request.auth.token.get("email", "").matches("^admin.*") ? "admin" : "staff") 
          : "student"
        );
    }

    function staffOrAdmin() {
      return role() in ["staff", "admin"];
    }

    function admin() {
      return role() == "admin";
    }

    match /users/{userId} {
      allow read: if signedIn() && (request.auth.uid == userId || staffOrAdmin());
      allow create: if signedIn() && request.auth.uid == userId
        && !("role" in request.resource.data);
      allow update: if signedIn() && request.auth.uid == userId
        && !("role" in request.resource.data.diff(resource.data).changedKeys());
      allow delete: if false;
    }

    match /menuItems/{itemId} {
      allow read: if true;
      allow write: if staffOrAdmin();
    }

    match /orders/{orderId} {
      allow read: if signedIn()
        && (resource.data.userId == request.auth.uid || staffOrAdmin());
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if signedIn() && staffOrAdmin();
      allow delete: if false;
    }

    match /paymentAttempts/{attemptId} {
      allow read: if signedIn()
        && (resource.data.userId == request.auth.uid || staffOrAdmin());
      allow write: if false;
    }

    match /stats/{statId} {
      allow read: if admin();
      allow write: if false;
    }

    match /counters/{counterId} {
      allow read, write: if false;
    }

    match /rateLimits/{userId} {
      allow read, write: if false;
    }
  }
}
