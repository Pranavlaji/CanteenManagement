rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function profileRoleById(userId) {
      return exists(/databases/$(database)/documents/users/$(userId))
        ? get(/databases/$(database)/documents/users/$(userId)).data.get(
            "role",
            get(/databases/$(database)/documents/users/$(userId)).data.get("roleDisplay", "student")
          )
        : "student";
    }

    function profileRole() {
      return profileRoleById(request.auth.uid) != "student"
        ? profileRoleById(request.auth.uid)
        : (
          request.auth.token.get("email", "") != ""
            ? profileRoleById(request.auth.token.get("email", ""))
            : "student"
        );
    }

    // Unified role detection: prioritize custom claims, fall back to email pattern.
    // Matches the same logic used in storage.rules and auth-provider.tsx.
    function role() {
      return !signedIn() ? "student" :
        (request.auth.token.get("role", null) != null
          ? request.auth.token.get("role", "student")
          : (profileRole() != "student"
            ? profileRole()
            : (request.auth.token.get("email", "").matches(".*@canteen\\.internal")
              ? (request.auth.token.get("email", "").matches("^admin.*") ? "admin" : "staff")
              : "student"
            )
          )
        );
    }

    function staffOrAdmin() {
      return role() in ["staff", "admin"];
    }

    function admin() {
      return role() == "admin";
    }

    match /users/{userId} {
      allow read: if signedIn() && (
        request.auth.uid == userId
        || request.auth.token.get("email", "") == userId
        || resource.data.get("email", "") == request.auth.token.get("email", "")
        || staffOrAdmin()
      );
      allow create: if signedIn() && request.auth.uid == userId
        && !("role" in request.resource.data);
      allow update: if signedIn() && request.auth.uid == userId
        && !("role" in request.resource.data.diff(resource.data).changedKeys());
      allow delete: if false;
    }

    match /menuItems/{itemId} {
      allow read: if true;
      allow write: if staffOrAdmin();
    }

    match /orders/{orderId} {
      allow read: if signedIn()
        && (resource.data.userId == request.auth.uid || staffOrAdmin());

      // Orders are ONLY created server-side via Admin SDK (API route).
      // Client-side create is blocked to prevent fake "captured" orders.
      allow create: if false;

      allow update: if signedIn() && staffOrAdmin();
      allow delete: if false;
    }

    match /paymentAttempts/{attemptId} {
      allow read: if signedIn()
        && (resource.data.userId == request.auth.uid || staffOrAdmin());
      allow write: if false;
    }

    match /stats/{statId} {
      allow read: if admin();
      allow write: if false;
    }

    match /counters/{counterId} {
      allow read, write: if false;
    }

    match /rateLimits/{userId} {
      allow read, write: if false;
    }
  }
}
